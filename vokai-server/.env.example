DIRECT_URL=postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_<your-public-key>
GEMINI_API_KEY=<your-gemini-api-key>
# Optional. Change only if your Gemini project uses a different supported model.
GEMINI_MODEL=gemini-2.5-flash
# Keep Cloudinary credentials on the server only. Never use EXPO_PUBLIC_ for these values.
CLOUDINARY_CLOUD_NAME=<your-cloud-name>
CLOUDINARY_API_KEY=<your-api-key>
CLOUDINARY_API_SECRET=<your-api-secret>
# Dodo Payments secrets stay on the server. Do not expose them with VITE_ or EXPO_PUBLIC_ prefixes.
DODO_PAYMENTS_API_KEY=<your-dodo-server-api-key>
DODO_PAYMENTS_ENVIRONMENT=test_mode
DODO_PAYMENTS_WEBHOOK_KEY=<your-dodo-webhook-signing-key>
DODO_WEEKLY_PRODUCT_ID=<your-weekly-product-id>
DODO_MONTHLY_PRODUCT_ID=<your-monthly-product-id>
DODO_YEARLY_PRODUCT_ID=<your-yearly-product-id>
# URL that Dodo redirects to after checkout. Use a public HTTPS URL in production.
DODO_CHECKOUT_RETURN_URL=https://<your-domain>/premium/complete
ALLOWED_ORIGINS=*
